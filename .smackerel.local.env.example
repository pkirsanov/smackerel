# Spec 061 SCOPE-06c — per-machine hardware-tier override (REQUIRED).
# Copy this file to `.smackerel.local.env` (gitignored) and fill in the tier
# value for THIS machine. `./smackerel.sh config generate` aborts fail-loud
# with [F061-HARDWARE-TIER-MISSING] if SMACKEREL_HARDWARE_TIER is unset.
#
# Allowed values:
#   SMACKEREL_HARDWARE_TIER=cpu     # WSL2 / Cloud PC / commodity host (no GPU/NPU)
#   SMACKEREL_HARDWARE_TIER=accel   # Evo-X2 / ROCm / CUDA / NPU-capable host
#
# The tier selects the interactive-role model for retrieval-qa and other
# user-facing scenarios; see config/smackerel.yaml::models.tiers and
# design.md §5.1 for the full matrix.
SMACKEREL_HARDWARE_TIER=
