# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
site-packages/
.venv/
venv/
.Python
.pytest_cache/
.ruff_cache/

# Generated config (contains resolved secrets)
config/generated/

# Spec 061 SCOPE-06c — per-machine hardware-tier override (operator-private,
# never committed). Template lives at .smackerel.local.env.example.
.smackerel.local.env

# Runtime data directories (user import data)
# BUG-029-005: track .gitkeep anchors at the 4 connector-fixture mount
# paths so fresh-clone bootstrap satisfies fail-loud Compose substitution
# without operator setup. Pattern uses `data/*` + un-excluded parent dirs
# because git cannot re-include a file inside an excluded directory.
data/*
!data/bookmarks-import/
!data/maps-import/
!data/browser-history/
!data/browser-history/History/
!data/twitter-archive/
data/bookmarks-import/*
data/maps-import/*
data/browser-history/History/*
data/twitter-archive/*
!data/bookmarks-import/.gitkeep
!data/maps-import/.gitkeep
!data/browser-history/History/.gitkeep
!data/twitter-archive/.gitkeep

# Database backups (contain full DB content including tokens)
backups/

# Secrets and credentials
*.key
*.pem
*.p12
.env
.env.*
secrets.yaml

# IDE / editor
.idea/
*.swp
*.swo
*~
.vscode/settings.json

# OS
.DS_Store
Thumbs.db

# Go
vendor/

# Node (if ever added)
node_modules/

# Spec 077 SCOPE-1b — Playwright artifacts for the PWA e2e-ui harness.
# Generated under web/pwa/ by `./smackerel.sh test e2e-ui` (Playwright
# reporters write here). Never committed.
web/pwa/test-results/
web/pwa/playwright-report/

# Temp / build
tmp/
*.tmp
*.log

# Prevent Bubbles framework README from overriding project README on GitHub
.github/README.md
# Built binaries at repo root (not the cmd/*/ source directories)
/core
/config-validate

# Test output files at repo root (captured by ad-hoc runs)
test_output.txt
integration_output.txt
*_output.txt
# Ad-hoc local debug artifacts at repo root (may contain PII such as filesystem
# paths or tailnet CGNAT IPs — must never be committed)
/file_list.txt
/output.txt
/results.txt
.vscode/tasks.json
.copilot-temp/

