{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/pkirsanov/bubbles/schemas/capability-ledger.schema.json",
  "title": "Bubbles capability ledger",
  "type": "object",
  "required": ["capabilities"],
  "additionalProperties": true,
  "properties": {
    "schemaVersion": { "type": "integer" },
    "capabilities": {
      "type": "object",
      "patternProperties": {
        "^[a-z][a-z0-9-]*$": {
          "type": "object",
          "required": ["label", "state", "summary"],
          "additionalProperties": true,
          "properties": {
            "label": { "type": "string", "minLength": 1 },
            "state": {
              "type": "string",
              "enum": ["shipped", "partial", "proposed", "deprecated"]
            },
            "summary": {
              "type": "string",
              "minLength": 10
            },
            "ownerSurface": { "type": "string" },
            "releaseIntroduced": { "type": "string" },
            "docsRefs": {
              "type": "array",
              "items": { "type": "string" }
            },
            "evidenceRefs": {
              "type": "array",
              "items": { "type": "string" }
            },
            "consumers": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Executable surfaces (scripts/agents/tools) that actually USE this capability. A shipped capability with no real consumer is an orphan (the IMP-001 R2-B failure mode); listing consumers makes the wiring auditable. Candidate for a future framework-dogfood freshness check (see improvements/IMP-004)."
            },
            "competitorContrast": { "type": "string" },
            "successOver": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      },
      "additionalProperties": false
    }
  }
}
