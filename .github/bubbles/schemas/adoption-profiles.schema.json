{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/pkirsanov/bubbles/schemas/adoption-profiles.schema.json",
  "title": "Bubbles adoption profiles",
  "type": "object",
  "required": ["profiles"],
  "additionalProperties": true,
  "properties": {
    "version": { "type": "integer" },
    "profiles": {
      "type": "object",
      "patternProperties": {
        "^[a-z][a-z0-9-]*$": {
          "type": "object",
          "required": ["id", "label", "description"],
          "additionalProperties": true,
          "properties": {
            "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
            "label": { "type": "string", "minLength": 1 },
            "description": { "type": "string", "minLength": 10 },
            "intendedAudience": { "type": "string" },
            "bootstrapSummary": { "type": "string" },
            "doctorProjectReadiness": { "type": "string" },
            "repoReadinessPosture": { "type": "string" },
            "docsFrontDoor": { "type": "string" }
          }
        }
      },
      "additionalProperties": false
    }
  }
}
