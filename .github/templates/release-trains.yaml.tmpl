# Release Trains Schema (per-repo `config/release-trains.yaml`)
#
# Owned by bubbles.train. This file is the per-repo registry of named release
# trains. Operator-chosen string ids; framework is name-agnostic.
#
# Copy this template to config/release-trains.yaml in your repo, edit values,
# commit. release-train-guard.sh validates it at pre-push.

version: 1

# Global per-repo defaults applied to every train unless overridden.
defaults:
  retention: "7d-daily,4w-weekly,12m-monthly"   # backup retention (G118)
  pii: "none"                                    # backup PII classification (G120)
  offsite_required: false                        # G116 warn-vs-block toggle

trains:
  # Example: MVP train, shipping to prod, default-active.
  - id: mvp
    phase: active                # active | maintained | frozen | retired
    target_slot: prod            # prod | staging | none
    flags_bundle: config/feature-flags.mvp.yaml
    retention: "7d-daily,4w-weekly,12m-monthly"   # overrides defaults if present
    pii: "pseudonymized"                          # overrides defaults if present
    description: "Current production train (MVP feature set)"

  # Example: Next-version train, shipping to staging for soak.
  - id: next
    phase: active
    target_slot: staging
    flags_bundle: config/feature-flags.next.yaml
    description: "Next promotion candidate; soaking on staging"

  # Example: Experimental train, build-only (never deployed).
  - id: experimental
    phase: maintained
    target_slot: none
    flags_bundle: config/feature-flags.experimental.yaml
    description: "Experimental features; build-only, no deploy slot"
