{
  "name": "smackerel-chrome-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "Smackerel Chrome MV3 extension that streams bookmarks + browser history into the smackerel-core ingest endpoint (spec 058).",
  "type": "module",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/node": "^20.12.7",
    "esbuild": "^0.21.5",
    "fake-indexeddb": "^6.0.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
