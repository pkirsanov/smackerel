  "streams": {
    "ARTIFACTS": { "subjects_pattern": "artifacts.>" },
    "SEARCH": { "subjects_pattern": "search.>" },
    "DIGEST": { "subjects_pattern": "digest.>" },
    "KEEP": { "subjects_pattern": "keep.>" },
    "INTELLIGENCE": { "subjects_pattern": "learning.>", "additional_subjects": ["content.>", "monthly.>", "quickref.>", "seasonal.>"] },
    "ALERTS": { "subjects_pattern": "alerts.>" },
    "DEADLETTER": { "subjects_pattern": "deadletter.>" }
  },
  "request_response_pairs": [
    { "request": "artifacts.process", "response": "artifacts.processed" },
    { "request": "search.embed", "response": "search.embedded" },
    { "request": "search.rerank", "response": "search.reranked" },
    { "request": "digest.generate", "response": "digest.generated" },
    { "request": "keep.sync.request", "response": "keep.sync.response" },
    { "request": "keep.ocr.request", "response": "keep.ocr.response" },
    { "request": "learning.classify", "response": "learning.classified" },
    { "request": "content.analyze", "response": "content.analyzed" },
    { "request": "monthly.generate", "response": "monthly.generated" },
    { "request": "quickref.generate", "response": "quickref.generated" },
    { "request": "seasonal.analyze", "response": "seasonal.analyzed" }
  ]
