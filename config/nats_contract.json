      "response": "artifacts.processed",
      "stream": "ARTIFACTS",
      "critical": true
    },
    "artifacts.processed": {
      "direction": "ml_to_core",
      "request": "artifacts.process",
      "stream": "ARTIFACTS",
      "critical": false
    },
    "search.embed": {
