    },
    "keep.sync.response": {
      "direction": "ml_to_core",
      "request": "keep.sync.request",
      "stream": "KEEP",
      "critical": false
    },
    "keep.ocr.request": {
      "direction": "core_to_ml",
      "response": "keep.ocr.response",
      "stream": "KEEP",
      "critical": false
    },
    "keep.ocr.response": {
      "direction": "ml_to_core",
      "request": "keep.ocr.request",
      "stream": "KEEP",
      "critical": false
    },
    "learning.classify": {
      "direction": "core_to_ml",
      "response": "learning.classified",
      "stream": "INTELLIGENCE",
      "critical": false
    },
    "learning.classified": {
      "direction": "ml_to_core",
      "request": "learning.classify",
      "stream": "INTELLIGENCE",
