# =============================================================================
# Smackerel Configuration — REFERENCE ONLY
# =============================================================================
# Single source of truth: config/smackerel.yaml
# Generate runtime env files: ./smackerel.sh config generate
#
# DO NOT EDIT port values here. All ports originate from config/smackerel.yaml
# under the environments.dev / environments.test sections. This file shows the
# generated env shape for onboarding reference only. Actual runtime values are
# written to config/generated/{dev,test}.env by the config generate command.

PROJECT_NAME=smackerel
COMPOSE_PROJECT=smackerel

POSTGRES_USER=smackerel
POSTGRES_PASSWORD=smackerel
POSTGRES_DB=smackerel
POSTGRES_CONTAINER_PORT=5432
POSTGRES_HOST_PORT=42001
POSTGRES_VOLUME_NAME=smackerel-postgres-data

NATS_CLIENT_PORT=4222
NATS_MONITOR_PORT=8222
NATS_CLIENT_HOST_PORT=42002
NATS_MONITOR_HOST_PORT=42003
NATS_VOLUME_NAME=smackerel-nats-data

CORE_CONTAINER_PORT=8080
CORE_HOST_PORT=40001
ML_CONTAINER_PORT=8081
ML_HOST_PORT=40002

OLLAMA_CONTAINER_PORT=11434
OLLAMA_HOST_PORT=42004
OLLAMA_VOLUME_NAME=smackerel-ollama-data
ENABLE_OLLAMA=false

DATABASE_URL=postgres://smackerel:smackerel@postgres:5432/smackerel?sslmode=disable
NATS_URL=nats://nats:4222
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2
LLM_API_KEY=
SMACKEREL_AUTH_TOKEN=development-change-me
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2
EMBEDDING_MODEL=all-MiniLM-L6-v2
DIGEST_CRON=0 7 * * *
LOG_LEVEL=info
PORT=8080
ML_SIDECAR_URL=http://smackerel-ml:8081
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_IDS=
CORE_EXTERNAL_URL=http://127.0.0.1:40001
ML_EXTERNAL_URL=http://127.0.0.1:40002
