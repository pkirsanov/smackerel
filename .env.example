# =============================================================================
# Smackerel Configuration
# =============================================================================
# Copy this file to .env and fill in required values.
# Missing required variables will cause startup failure with explicit error.

# --- Required ---

# PostgreSQL connection string
DATABASE_URL=postgres://smackerel:smackerel@postgres:5432/smackerel?sslmode=disable

# NATS connection URL
NATS_URL=nats://nats:4222

# LLM provider: openai, anthropic, ollama, etc. (passed to litellm)
LLM_PROVIDER=

# LLM model name (e.g., gpt-4o-mini, claude-sonnet-4-20250514, ollama/llama3)
LLM_MODEL=

# LLM API key (required unless using Ollama)
LLM_API_KEY=

# Bearer token for API authentication (single-user MVP)
SMACKEREL_AUTH_TOKEN=

# --- Optional ---

# Telegram bot token (omit to disable Telegram integration)
# TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram chat IDs allowed to interact with the bot
# TELEGRAM_CHAT_IDS=

# Ollama base URL (default: http://ollama:11434)
# OLLAMA_URL=http://ollama:11434

# Ollama model for local inference
# OLLAMA_MODEL=llama3

# Embedding model name (default: all-MiniLM-L6-v2)
# EMBEDDING_MODEL=all-MiniLM-L6-v2

# Digest generation cron expression (default: 0 7 * * *)
# DIGEST_CRON=0 7 * * *

# Log level: debug, info, warn, error (default: info)
# LOG_LEVEL=info

# Go API server port (default: 8080)
# PORT=8080

# Python ML sidecar port (default: 8081)
# ML_PORT=8081
